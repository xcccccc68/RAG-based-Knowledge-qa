# ====================================================
# 审计知识问答系统 - 环境变量示例
# 复制本文件为 .env 并填入实际值，切勿提交真实 .env
# ====================================================

# ---------- 服务配置 ----------
HOST=0.0.0.0
PORT=8000
CALLBACK_URL=

# ---------- LLM 配置 ----------
BASE_URL=
API_KEY=
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=30
LLM_CONTEXT_LENGTH=32768

# ---------- Embedding 配置 ----------
EMBEDDING_API_URL=
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_TIMEOUT=30

# ---------- Rerank 配置 ----------
RERANK_API_URL=
RERANK_MODEL_NAME=rerank-english-v2.0
RERANK_TIMEOUT=30

# ---------- 流式输出配置 ----------
STREAM_CHUNK_SIZE=50

# ---------- Milvus 向量数据库 ----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=documents
MILVUS_DIMENSION=1536

# ---------- Minio 对象存储 ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=documents
MINIO_SECURE=False

# ---------- Redis 缓存 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=True
REDIS_TIMEOUT=30
CONVERSATION_TIMEOUT=1800

# ---------- 高频问题缓存 ----------
QUESTION_CACHE_DB=3
QUESTION_CACHE_SIMILARITY_THRESHOLD=0.9

# ---------- 意图识别 ----------
INTENT_CONFIDENCE_THRESHOLD=0.7

# ---------- 分块 / 检索策略 ----------
CHUNKING_STRATEGY=generic
RETRIEVAL_MODE=hybrid

# ---------- 重召回 / 上下文压缩 ----------
ENABLE_RE_RANKING=True
MAX_CONTEXT_TOKENS=8000
ENABLE_CONTEXT_COMPRESSION=True

# ---------- Tika Server ----------
TIKA_SERVER_URL=

# ---------- PDF 处理 ----------
PDF_PROCESSOR_MODE=auto
ENABLE_OCR=False
